        "Website": "https://github.com/KenanSalar/plasma-gnome-pager",
        "BugReportUrl": "https://github.com/KenanSalar/plasma-gnome-pager/issues",
        "Authors": [
            {
                "Name": "Kenan Salar",
                "Email": ""
            }
        ]
    }
